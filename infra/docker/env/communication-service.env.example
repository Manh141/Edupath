NODE_ENV=development
PORT=3007
APP_NAME=communication-service
APP_ORIGIN=http://communication-service:3007
WEB_ORIGIN=http://localhost:3006

DATABASE_URL=postgresql://postgres:postgres@postgres-communication:5432/edupath_communication?schema=public

# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

REDIS_URL=redis://redis:6379

# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

COURSE_SERVICE_INTERNAL_URL=http://course-service:3003
ENROLLMENT_SERVICE_INTERNAL_URL=http://enrollment-service:3004
USER_SERVICE_INTERNAL_URL=http://user-service:3002
EXTERNAL_SERVICE_TIMEOUT_MS=5000

REVIEW_REQUIRE_ENROLLMENT=true
SOCKET_PATH=/socket.io
