NODE_ENV=development
SEED_DATABASE=true
PORT=3001
APP_NAME=auth-service
APP_ORIGIN=http://auth-service:3001
WEB_ORIGIN=http://localhost:3006

# Local docker-compose Postgres. For production, use a managed DB and a strong password.
DATABASE_URL=postgresql://postgres:postgres@postgres-auth:5432/edupath_auth?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Generate locally with:  openssl rand -hex 64
# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64
JWT_ACCESS_EXPIRES_IN=15m
JWT_ACCESS_ISSUER=edupath-auth
JWT_ACCESS_AUDIENCE=edupath-web
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

AUTH_CHALLENGE_EXPIRES_IN_MINUTES=10
AUTH_CHALLENGE_MAX_ATTEMPTS=5
AUTH_CHALLENGE_MAX_RESENDS=3

OAUTH_STATE_EXPIRES_IN_MINUTES=10
OAUTH_EXCHANGE_CODE_EXPIRES_IN_MINUTES=5

# Email transport. Use a Gmail App Password, not your real password:
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailer@example.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=your-mailer@example.com
MAIL_FROM_NAME=EduPath

USER_SERVICE_URL=http://user-service:3002

# Generate locally with:  openssl rand -hex 32
# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

# Bootstrap admins seeded on first startup. Use STRONG, unique passwords.
# forcePasswordChange=true forces the user to change password on first login.
ADMIN_ACCOUNTS_JSON=[{"email":"admin@example.com","password":"change-me-strong-password","role":"admin","forcePasswordChange":true}]

# Expose OTP code in response body for local debugging only. NEVER true in production.
EXPOSE_OTP_IN_RESPONSE=false

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Facebook OAuth — leave empty to disable
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
