NODE_ENV=development
PORT=3006

# When the web container is in the same docker network, talk to api-gateway by service name.
NEXT_PUBLIC_API_URL=http://api-gateway:3000
NEXT_INTERNAL_API_BASE_URL=http://api-gateway:3000

# When the browser hits the api-gateway, it must use the host-mapped URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

NEXT_PUBLIC_COMMUNICATION_WS_URL=http://localhost:3007
