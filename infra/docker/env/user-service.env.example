NODE_ENV=development
SEED_DATABASE=true
PORT=3002
APP_NAME=user-service
APP_ORIGIN=http://user-service:3002
CORS_ORIGIN=http://localhost:3006

DATABASE_URL=postgresql://postgres:postgres@postgres-user:5432/edupath_user?schema=public

REDIS_URL=redis://redis:6379

# MinIO object storage (must match values in minio.env).
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

AUTH_SERVICE_URL=http://auth-service:3001
EXTERNAL_SERVICE_TIMEOUT_MS=5000
