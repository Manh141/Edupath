# MinIO root credentials — used by the docker-compose MinIO container.
# These also serve as the S3 access/secret keys for services that talk to MinIO.
# Use a strong password (>= 12 chars). Rotate before any non-local deploy.
MINIO_ROOT_USER=your-minio-access-key
MINIO_ROOT_PASSWORD=your-minio-secret-key-min-12-chars
