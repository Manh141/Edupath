NODE_ENV=development
PORT=3000
APP_NAME=api-gateway
WEB_ORIGIN=http://localhost:3006

# Must match JWT_ACCESS_SECRET used by auth-service.
# Generate locally with:  openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

# Shared secret used for service-to-service calls. Must match every service.
# Generate locally with:  openssl rand -hex 32
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

# Internal service URLs (docker network DNS names)
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
COURSE_SERVICE_URL=http://course-service:3003
ENROLLMENT_SERVICE_URL=http://enrollment-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
COMMUNICATION_SERVICE_URL=http://communication-service:3007

PROXY_TIMEOUT_MS=600000
