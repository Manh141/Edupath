NODE_ENV=development
SEED_DATABASE=true
PORT=3003
APP_NAME=course-service
APP_ORIGIN=http://course-service:3003
WEB_ORIGIN=http://localhost:3006

DATABASE_URL=postgresql://postgres:postgres@postgres-course:5432/edupath_course?schema=public

# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

REDIS_URL=redis://redis:6379

# S3 / MinIO object storage for course media.
# Values below match the local docker-compose MinIO instance — change for production.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_BUCKET=edupath-course
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/edupath-course
S3_UPLOAD_ENDPOINT=http://localhost:9000
S3_AUTO_SETUP=true

# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

ENROLLMENT_SERVICE_INTERNAL_URL=http://enrollment-service:3004
PAYMENT_SERVICE_INTERNAL_URL=http://payment-service:3005

REQUIRE_INSTRUCTOR_IDENTITY=false
REQUIRE_INSTRUCTOR_MONETIZATION_FOR_PAID=true
