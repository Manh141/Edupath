NODE_ENV=development
SEED_DATABASE=true
PORT=3004
APP_NAME=enrollment-service
APP_ORIGIN=http://enrollment-service:3004

DATABASE_URL=postgresql://postgres:postgres@postgres-enrollment:5432/edupath_enrollment?schema=public

REDIS_URL=redis://redis:6379

COURSE_SERVICE_URL=http://course-service:3003
CORS_ORIGIN=http://localhost:3006

# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32
