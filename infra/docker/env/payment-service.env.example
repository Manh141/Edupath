NODE_ENV=development
PORT=3005
APP_NAME=payment-service
API_PREFIX=api
WEB_ORIGIN=http://localhost:3006
APP_ORIGIN=http://payment-service:3005

DATABASE_URL=postgresql://postgres:postgres@postgres-payment:5432/edupath_payment?schema=public

# Must match JWT_ACCESS_SECRET in every other service.
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-64

REDIS_URL=redis://redis:6379

COURSE_SERVICE_URL=http://course-service:3003
ENROLLMENT_SERVICE_URL=http://enrollment-service:3004

SWAGGER_TITLE=EduPath Payment Service
SWAGGER_DESCRIPTION=Payment, cart, coupon, order and transaction service
SWAGGER_VERSION=1.0.0

BULLMQ_PREFIX=edupath
PAYMENT_QUEUE_NAME=payment-events
DEFAULT_CURRENCY=VND
ORDER_TTL_MINUTES=30
PAYMENT_CALLBACK_BASE_URL=http://localhost:3005

# Generate locally with:  openssl rand -hex 32
# Used to sign provider callback URLs — keep secret.
PAYMENT_CALLBACK_SECRET=replace-with-openssl-rand-hex-32

# Must match INTERNAL_SERVICE_SECRET in every other service.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32

# AES-GCM key for encrypting payment PII at rest.
# Generate locally with:  openssl rand -base64 32
PAYMENT_PII_KEY_BASE64=replace-with-base64-encoded-32-byte-key

# Enable sandbox endpoint to simulate payment outcomes in dev / demo.
# MUST be false in production.
PAYMENT_SANDBOX_MODE=true
