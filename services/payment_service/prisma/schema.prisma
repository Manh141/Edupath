generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CartStatus {
  active
  converted
  abandoned
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
  refunded
  expired
}

enum PaymentMethod {
  momo
  vnpay
  stripe
  cod
  bank_transfer
  free
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
  cancelled
}

enum MonetizationStatus {
  not_started
  in_progress
  pending_payout
  active
  suspended
}

enum OnboardingStepStatus {
  pending
  completed
  skipped
}

enum PayoutAccountProvider {
  bank_transfer_vn
  paypal
  stripe_connect
}

enum PayoutAccountStatus {
  draft
  pending_review
  active
  rejected
  disabled
}

enum InstructorIdentityStatus {
  not_started
  pending
  verified
  rejected
}

enum TaxFormStatus {
  not_required
  required
  submitted
  accepted
  rejected
}

model Cart {
  id              String      @id @default(cuid())
  userId          String
  status          CartStatus  @default(active)
  currency        String      @default("VND")
  couponCode      String?
  items           CartItem[]
  convertedOrderId String?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, status])
  @@index([updatedAt])
}

model CartItem {
  id                  String   @id @default(cuid())
  cartId              String
  cart                Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  courseId            String
  courseTitle         String
  courseThumbnailUrl  String   @default("")
  instructorName      String   @default("")
  unitPrice           Int
  currency            String   @default("VND")
  createdAt           DateTime @default(now())

  @@unique([cartId, courseId])
  @@index([courseId])
}

model Coupon {
  id                String   @id @default(cuid())
  code              String   @unique
  description       String   @default("")
  discountPercent   Int?
  discountAmount    Int?
  maxDiscountAmount Int?
  minOrderAmount    Int?
  usageLimit        Int?
  usedCount         Int      @default(0)
  startsAt          DateTime?
  endsAt            DateTime?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders            Order[]
}

model Order {
  id                    String               @id @default(cuid())
  userId                String
  couponId              String?
  couponCodeSnapshot    String?
  coupon                Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  status                OrderStatus          @default(pending)
  subtotalAmount        Int
  discountAmount        Int                  @default(0)
  totalAmount           Int
  currency              String               @default("VND")
  expiresAt             DateTime?
  paidAt                DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  refundedAt            DateTime?
  failureReason         String?
  sourceCartId          String?
  idempotencyKey        String?
  items                 OrderItem[]
  transactions          PaymentTransaction[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([userId, status])
  @@index([createdAt])
  @@unique([userId, idempotencyKey])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId            String
  courseTitle         String
  courseThumbnailUrl  String   @default("")
  instructorName      String   @default("")
  unitPrice           Int
  finalPrice          Int
  currency            String   @default("VND")
  createdAt           DateTime @default(now())

  @@index([orderId])
  @@index([courseId])
  @@unique([orderId, courseId])
}

model PaymentTransaction {
  id                    String         @id @default(cuid())
  orderId               String
  order                 Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider              PaymentMethod
  providerRef           String?
  providerPaymentUrl    String?
  status                PaymentStatus  @default(pending)
  amount                Int
  currency              String         @default("VND")
  paidAt                DateTime?
  failureReason         String?
  rawResponse           Json?
  callbackChecksum      String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([orderId])
  @@index([providerRef])
  @@index([status])
}

model InstructorMonetizationProfile {
  id                    String                      @id @default(cuid())
  instructorId          String                      @unique

  legalName             String?
  companyName           String?
  publicHeadline        String?
  shortBio              String?
  profileImageUrl       String?

  acceptedTermsVersion  String?
  acceptedTermsAt       DateTime?
  acceptedPromotional   Boolean                     @default(false)
  acceptedPromotionalAt DateTime?

  status                MonetizationStatus          @default(not_started)
  identityStatus        InstructorIdentityStatus    @default(not_started)
  taxFormStatus         TaxFormStatus               @default(not_required)

  payoutAccounts        PayoutAccount[]
  onboardingSteps       OnboardingStepProgress[]
  eligibilitySnapshots  SellerEligibilitySnapshot[]

  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([status])
}

model OnboardingStepProgress {
  id          String                         @id @default(cuid())
  profileId   String
  profile     InstructorMonetizationProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  stepKey     String
  status      OnboardingStepStatus           @default(pending)
  completedAt DateTime?
  payload     Json?

  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt

  @@unique([profileId, stepKey])
  @@index([profileId])
}

model PayoutAccount {
  id               String                         @id @default(cuid())
  profileId        String
  profile          InstructorMonetizationProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  provider         PayoutAccountProvider
  status           PayoutAccountStatus            @default(draft)
  displayName      String
  holderNameCipher String?
  accountRefCipher String?
  accountRefMasked String?
  bankCode         String?
  country          String                         @default("VN")
  currency         String                         @default("VND")

  submittedAt      DateTime?
  activatedAt      DateTime?
  rejectedReason   String?
  isDefault        Boolean                        @default(false)

  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@index([profileId, status])
}

model SellerEligibilitySnapshot {
  id          String                         @id @default(cuid())
  profileId   String
  profile     InstructorMonetizationProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  canSellPaid Boolean                        @default(false)
  reasons     Json
  computedAt  DateTime                       @default(now())

  @@index([profileId, computedAt])
}
