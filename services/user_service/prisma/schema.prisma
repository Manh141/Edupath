generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  banned
}

model UserProfile {
  id                String             @id
  email             String             @unique
  fullName          String
  avatarUrl         String             @default("")
  headline          String             @default("")
  bio               String             @default("")
  phone             String             @default("")
  country           String             @default("")
  language          String             @default("vi")
  status            UserStatus         @default(active)
  isInstructor      Boolean            @default(false)
  instructorProfile InstructorProfile?
  preferences       UserPreference?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
  @@index([isInstructor])
  @@map("user_profiles")
}

model InstructorProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String
  title         String      @default("")
  about         String      @default("")
  websiteUrl    String      @default("")
  twitterUrl    String      @default("")
  linkedinUrl   String      @default("")
  youtubeUrl    String      @default("")
  totalStudents Int         @default(0)
  totalCourses  Int         @default(0)
  averageRating Float       @default(0)
  totalReviews  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("instructor_profiles")
}

model UserPreference {
  id                 String      @id @default(cuid())
  userId             String      @unique
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteCategories String[]    @default([])
  learningGoals      String[]    @default([])
  preferredLanguage  String      @default("vi")
  updatedAt          DateTime    @updatedAt

  @@map("user_preferences")
}